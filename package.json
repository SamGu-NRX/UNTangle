{
  "name": "UNTangle",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "setup": "node scripts/dev.mjs --setup-only",
    "backend:install": "cd backend && bun install --frozen-lockfile",
    "backend:check": "cd backend && bun run check",
    "backend:seed": "cd backend && bun run seed",
    "backend:dev": "cd backend && bun run dev",
    "frontend:dev": "cd frontend && bun run dev",
    "dev": "node scripts/dev.mjs",
    "dev:turbo": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2.8.19"
  },
  "packageManager": "bun@1.3.10"
}
