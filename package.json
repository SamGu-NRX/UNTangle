{
  "name": "UNTangle",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "setup": "git submodule update --init --recursive && bun install --frozen-lockfile && (cd backend && bun install --frozen-lockfile)",
    "backend:install": "cd backend && bun install --frozen-lockfile",
    "backend:check": "cd backend && bun run check",
    "backend:seed": "cd backend && bun run seed",
    "backend:dev": "cd backend && bun run dev",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2.8.19"
  },
  "packageManager": "bun@1.3.10"
}
